# --- Workspace by TurkishSystems .gitignore ---

# Bağımlılıklar (Dependencies)
node_modules/
jspm_packages/
.pnp
.pnp.js

# Üretim Çıktıları (Build Outputs)
dist/
build/
.next/
out/
bin/
obj/

# Ortam Değişkenleri (Security - Önemli!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env.bak

# Log Dosyaları
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# IDE & Editor Ayarları
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# İşletim Sistemi Dosyaları
.DS_Store
Thumbs.db
desktop.ini

# Test & Kapsam Raporları
coverage/
.nyc_output/

# TypeScript & Cache
*.tsbuildinfo
.eslintcache
.stylelintcache
.node_repl_history
.cache/

# Yedeklemeler ve Geçici Dosyalar
*.bak
*.tmp
*.temp
temp/
backup/

# --- TurkishSystems Özel ---
# Eğer proje içinde yerel veritabanı dosyaları tutuluyorsa:
*.sqlite
*.db